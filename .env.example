# Google OAuth Configuration

# Web OAuth Client (for backstage admin and web apps)
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_SECRET=your-web-client-secret

# iOS OAuth Client (for mobile app - no client_secret needed)
GOOGLE_IOS_CLIENT_ID=498782874156-vdhctn0cc6uh2jlvaoa01surqg9lnop5.apps.googleusercontent.com

# Legacy variables (backward compatibility - will use WEB_CLIENT values if set)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-min-32-chars-generate-with-openssl-rand-hex-32

# Authorization
AUTHORIZED_EMAILS=admin@example.com,dev@example.com

# URLs
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CLIENT_APP_URL=http://localhost:65263

# Token Settings
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (Note: For development, config.yaml uses regex to allow all localhost ports)
# For production, set specific origins:
# CORS_ORIGINS=https://yourapp.com,https://www.yourapp.com
